# Sanity v3 — front-end (Vite) reads VITE_-prefixed vars
VITE_SANITY_PROJECT_ID=your_project_id_here
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01

# Sanity Studio (read from studio/sanity.config.js)
SANITY_STUDIO_PROJECT_ID=your_project_id_here
SANITY_STUDIO_DATASET=production

# Vercel deploy hook fired by Sanity webhook on publish
# Create at: Vercel project → Settings → Git → Deploy Hooks
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/REPLACE_ME
